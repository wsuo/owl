ARG RUNTIME_IMAGE=gospace/gowvp@sha256:e7f6dcc4bde7b3fc3a63b7a5097538bc25417ddd4e1443df3478516666e48bd0
FROM ${RUNTIME_IMAGE}

ARG TARGETARCH
WORKDIR /opt/media/bin/

# Reuse the production-tested ZLM/runtime layer and replace only the fork binary
# and the pinned management UI assets.
COPY ./build/linux_${TARGETARCH}/bin ./gowvp
COPY ./www ./www

RUN chmod +x ./gowvp

LABEL Name=gowvp \
      Description="gowvp & zlmediakit"

CMD ["./gowvp"]
